{
    "name": "svg-asset-builder",
    "version": "1.0.0",
    "private": true,
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "test": "turbo run test",
        "dev": "turbo run dev",
        "dev:web": "turbo run dev --filter=web",
        "dev:api": "turbo run dev --filter=api",
        "build": "turbo run build",
        "build:web": "turbo run build --filter=web",
        "build:api": "turbo run build --filter=api",
        "typecheck": "turbo run typecheck",
        "lint": "turbo run lint",
        "format": "prettier --write .",
        "prisma:generate": "pnpm --filter=api prisma generate",
        "prisma:migrate": "pnpm --filter=api prisma migrate dev",
        "docker:up": "docker-compose --env-file .env up -d",
        "docker:down": "docker-compose --env-file .env down",
        "docker:build": "docker-compose --env-file .env up -d --build",
        "docker:logs": "docker-compose --env-file .env logs -f",
        "docker:dev": "docker-compose -f docker-compose.dev.yml --env-file .env up -d",
        "docker:dev:down": "docker-compose -f docker-compose.dev.yml --env-file .env down",
        "docker:clean": "docker-compose --env-file .env down -v && docker system prune -f"
    },
    "devDependencies": {
        "@prisma/client": "5.14.0",
        "@types/archiver": "^7.0.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.57.0",
        "prettier": "^3.0.0",
        "prisma": "5.14.0",
        "turbo": "^2.0.0",
        "typescript": "^5.4.0"
    }
}
