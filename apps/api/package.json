    "@svg-builder/svg-core": "workspace:*",
    "archiver": "^8.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "pino": "^8.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^20.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
