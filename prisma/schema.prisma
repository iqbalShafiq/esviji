generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  email        String      @unique
  passwordHash String
  role         String      @default("user") // user | admin
  tokenBalance Int         @default(50)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assets Asset[]
  packs  AssetPack[]
}

model Asset {
  id                String    @id @default(cuid())
  ownerId           String?
  packId            String?
  sourceAssetId     String?
  name              String?
  prompt            String
  assetType         String
  mode              String // direct | reference | premium
  style             String?
  visibility        String    @default("private") // private | public
  status            String    @default("pending") // pending | processing | completed | failed
  width             Int
  height            Int
  referenceImageUrl String?
  finalSvgPath      String?
  finalPngPath      String?
  finalDebugPngPath String?
  currentIteration  Int       @default(0)
  bestIterationNumber Int?    
  finalScores       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner      User?            @relation(fields: [ownerId], references: [id])
  pack       AssetPack?       @relation(fields: [packId], references: [id])
  iterations AssetIteration[]

  @@index([ownerId])
  @@index([visibility])
  @@index([sourceAssetId])
}

model AssetPack {
  id                  String   @id @default(cuid())
  ownerId             String?
  sourcePackId        String?
  prompt              String
  assetType           String
  quantity            Int
  style               String?
  visibility          String   @default("private")
  status              String   @default("pending")
  styleSystem         Json
  consistencyScores   Json?
  zipPath             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner  User?   @relation(fields: [ownerId], references: [id])
  assets Asset[]

  @@index([ownerId])
  @@index([visibility])
  @@index([sourcePackId])
}

model AssetIteration {
  id                String   @id @default(cuid())
  assetId           String
  iterationNumber   Int
  brief             Json
  styleSystem       Json
  referenceAnalysis Json?
  layout            Json
  svgDraftPath      String?
  pngPreviewPath    String?
  debugPreviewPath  String?
  scores            Json?
  issues            Json?
  actionTaken       Json?
  createdAt         DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
}
