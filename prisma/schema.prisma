generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  email        String      @unique
  passwordHash String
  role         String      @default("user") // user | admin
  tokenBalance Int         @default(50)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assets Asset[]
  packs  AssetPack[]
  paymentOrders PaymentOrder[]
  tokenLedgerEntries TokenLedgerEntry[]
}

model TokenPackage {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  tokenAmount Int
  priceIdr    Int
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paymentOrders PaymentOrder[]

  @@index([isActive, sortOrder])
}

model PaymentOrder {
  id                 String    @id @default(cuid())
  userId             String
  packageId          String
  provider           String    @default("midtrans")
  providerOrderId    String    @unique
  providerTransactionId String?
  providerPaymentType String?
  status             String    @default("pending") // pending | paid | failed | expired | cancelled | refunded | partial_refund | chargeback | review
  amountIdr          Int
  tokenAmount        Int
  snapToken          String?
  snapRedirectUrl    String?
  failureReason      String?
  needsManualReview  Boolean   @default(false)
  paidAt             DateTime?
  tokenCreditedAt    DateTime?
  tokenRevokedAt     DateTime?
  refundedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User         @relation(fields: [userId], references: [id])
  package TokenPackage @relation(fields: [packageId], references: [id])
  events  PaymentEvent[]
  ledgerEntries TokenLedgerEntry[]

  @@index([userId, createdAt])
  @@index([status])
}

model PaymentEvent {
  id              String   @id @default(cuid())
  paymentOrderId  String?
  provider        String   @default("midtrans")
  providerEventId String   @unique
  orderId         String?
  transactionId   String?
  transactionStatus String?
  fraudStatus     String?
  statusCode      String?
  grossAmount     String?
  signatureValid  Boolean  @default(false)
  rawPayload      Json
  createdAt       DateTime @default(now())

  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([paymentOrderId, createdAt])
  @@index([orderId])
}

model TokenLedgerEntry {
  id             String   @id @default(cuid())
  userId         String
  paymentOrderId String?
  amount         Int
  type           String // signup_bonus | payment_credit | generation_reserve | generation_refund | payment_reversal | admin_adjustment
  note           String?
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([userId, createdAt])
  @@index([paymentOrderId])
}

model Asset {
  id                String    @id @default(cuid())
  ownerId           String?
  packId            String?
  sourceAssetId     String?
  name              String?
  prompt            String
  assetType         String
  mode              String // direct | reference | premium
  style             String?
  visibility        String    @default("private") // private | public
  status            String    @default("pending") // pending | processing | completed | failed
  width             Int
  height            Int
  referenceImageUrl String?
  finalSvgPath      String?
  finalPngPath      String?
  finalDebugPngPath String?
  currentIteration  Int       @default(0)
  bestIterationNumber Int?    
  finalScores       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner      User?            @relation(fields: [ownerId], references: [id])
  pack       AssetPack?       @relation(fields: [packId], references: [id])
  iterations AssetIteration[]

  @@index([ownerId])
  @@index([visibility])
  @@index([sourceAssetId])
}

model AssetPack {
  id                  String   @id @default(cuid())
  ownerId             String?
  sourcePackId        String?
  prompt              String
  assetType           String
  quantity            Int
  style               String?
  visibility          String   @default("private")
  status              String   @default("pending")
  styleSystem         Json
  consistencyScores   Json?
  zipPath             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner  User?   @relation(fields: [ownerId], references: [id])
  assets Asset[]

  @@index([ownerId])
  @@index([visibility])
  @@index([sourcePackId])
}

model AssetIteration {
  id                String   @id @default(cuid())
  assetId           String
  iterationNumber   Int
  brief             Json
  styleSystem       Json
  referenceAnalysis Json?
  layout            Json
  svgDraftPath      String?
  pngPreviewPath    String?
  debugPreviewPath  String?
  scores            Json?
  issues            Json?
  actionTaken       Json?
  createdAt         DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
}
