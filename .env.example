# OpenAI API Key for AI-powered SVG generation (OpenRouter API Key)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemini-3.1-flash-lite

# LangSmith Configuration
LANGSMITH_ENABLED=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=ls...
LANGSMITH_PROJECT=your_project_name

# Option 1: Local Development (without Docker)
# DATABASE_URL=postgresql://svgbuilder:svgbuilder_password@localhost:5432/svg_asset_builder

# Option 2: Docker Development (with docker-compose)
# The postgres service is available at hostname 'postgres' within Docker network
DATABASE_URL=postgresql://svgbuilder:svgbuilder_password@postgres:5432/svg_asset_builder

# Storage driver: local or s3
STORAGE_DRIVER=local

# Local storage directory (used when STORAGE_DRIVER=local)
# In Docker, this should be an absolute path or relative to the container
LOCAL_STORAGE_DIR=./storage

# API server port
API_PORT=4000

# API host (for CORS and internal communication)
# In Docker, use 0.0.0.0 to bind to all interfaces
API_HOST=0.0.0.0

# Frontend API base URL (used by Vite/React app)
# For local development: http://localhost:4000
# For Docker: http://localhost:4000 (or http://api:4000 within Docker network)
VITE_API_BASE_URL=http://localhost:4000

# PostgreSQL Configuration (used by docker-compose.yml)
POSTGRES_USER=svgbuilder
POSTGRES_PASSWORD=svgbuilder_password
POSTGRES_DB=svg_asset_builder
POSTGRES_PORT=5432

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=svg-asset-builder
